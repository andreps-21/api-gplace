APP_NAME=Shoplink
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8005

# Origens do browser autorizadas a chamar a API (CORS). Separar por vírgula. Produção: incluir https://gplace.gooding.solutions
CORS_ALLOWED_ORIGINS=https://gplace.gooding.solutions,http://localhost:3000,http://127.0.0.1:3000

# Docker Compose (raiz do repo): APP em http://localhost:8005, MySQL no host na porta 3311, phpMyAdmin 8085.
# Mantenha DB_HOST=127.0.0.1 para artisan na máquina; no contentor o AppServiceProvider aponta para o serviço mysql.
# Com Compose, use DB_PASSWORD=secret (igual ao MYSQL_ROOT_PASSWORD no docker-compose.yml).

LOG_CHANNEL=stack

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=loja
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=null
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=mt1

MIX_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
MIX_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# --- Integrações (opcional; ver config/*.php) ---
# PAGSEGURO_SANDBOX=true
# PAGSEGURO_EMAIL=
# PAGSEGURO_TOKEN=

